# Video PRO AI - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Pexels API Key (https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=your_pixabay_api_key_here

# Google Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Admin User ID
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# Apify API Token (https://apify.com/)
APIFY_API_TOKEN=your_apify_token_here

# Prototipal API Key (if used)
PROTOTIPAL_API_KEY=your_prototipal_key_here